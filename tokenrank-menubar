def is_dark():
    v = os.environ.get("OS_APPEARANCE")
    if v:
        return v.lower().startswith("d")
    try:
        out = subprocess.check_output(["defaults", "read", "-g", "AppleInterfaceStyle"],
                                      text=True, stderr=subprocess.DEVNULL, timeout=3).strip()
        return out == "Dark"
    except Exception:
        return False


# ---------- helpers ----------
def fmt_tokens(n):
    n = int(n or 0)
    if n >= 100_000_000:
        return f"{n/100_000_000:.2f}亿"
    if n >= 10_000:
        return f"{n/10_000:.1f}万"
    return f"{n:,}"


def fmt_short(n):
    """坐标轴刻度用：300万 / 1.5亿，无多余小数。"""
    if n >= 100_000_000:
        return f"{n/100_000_000:g}亿"
    if n >= 10_000:
        return f"{n/10_000:g}万"
    return f"{n:g}"


def nice_ticks(mx, target=3):
    """好看的整数刻度：步长取 1/2/2.5/5×10^k，如 300万/600万/900万。"""
    if mx <= 0:
        return 1, []
    raw = mx / target
    mag = 10 ** math.floor(math.log10(raw))
    step = mag
    for m in (1, 2, 2.5, 5, 10):
        step = m * mag
        if raw <= step:
            break
    top = math.ceil(mx / step) * step
    return top, [step * i for i in range(1, round(top / step) + 1)]


def today_str():
    return datetime.now().strftime("%Y-%m-%d")


def parse_dt(value):
    if value in (None, "", 0):
        return None
    try:
        if isinstance(value, (int, float)) or str(value).isdigit():
            return datetime.fromtimestamp(int(float(value)))
        dt = datetime.fromisoformat(str(value).replace("Z", "+00:00"))
        return dt.astimezone().replace(tzinfo=None)
    except Exception:
        return None


def countdown(value):
    dt = parse_dt(value)
    if not dt:
        return ""
    secs = int((dt - datetime.now()).total_seconds())
    if secs <= 0:
        return "即将重置"
    d, r = divmod(secs, 86400)
    h, r = divmod(r, 3600)
    m = r // 60
    if d > 0:
        return f"{d}d:{h}h"
    if h > 0:
        return f"{h}h:{m}m"
    return f"{m}m"


def sev_color(used):
    for thresh, color in SEV:
        if used >= thresh:
            return color
    return SEV[-1][1]


# 百分比文字专用高对比色板：与条同色相、只降明度（同一家颜色的深浅两档），
# 既保持“文字和条是一个颜色”的观感，又有足够对比度不被磨砂+壁纸洗淡
SEV_TEXT_LIGHT = [(85, "#d70015"), (60, "#a87b00"), (0, "#1e8e3e")]
SEV_TEXT_DARK = [(85, "#ff6259"), (60, "#ffd60a"), (0, "#30d158")]


def sev_text_color(used, dark):
    palette = SEV_TEXT_DARK if dark else SEV_TEXT_LIGHT
    for thresh, color in palette:
        if used >= thresh:
            return color
    return palette[-1][1]


def pct(v):
    try:
        v = float(v)
    except (TypeError, ValueError):
        return None
    if 0 < v <= 1.0:
        v *= 100
    return round(v)


